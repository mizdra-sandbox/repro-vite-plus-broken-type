// tsconfig.json for TypeScript files inside the src directory
{
  "extends": "./tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ESNext"],
    "module": "NodeNext",

    "composite": true,
    "sourceMap": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist"
  }
}
